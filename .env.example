# Kopiér til Vercel → Project → Settings → Environment Variables (Production).
# Bruges af /api/cms-login og /api/cms-save-overrides — IKKE commit rigtige værdier.

# Adgangskode til https://…/rediger/ (den redaktøren skriver — ikke GitHub).
CMS_ADMIN_PASSWORD=

# Tilfældig lang streng til underskrift af session-token (fx openssl rand -hex 32).
CMS_JWT_SECRET=

# GitHub PAT med skriveadgang til repo (Contents: Read and write).
# Bruges kun på serveren; besøgende ser den aldrig.
GITHUB_TOKEN=

# Repo der skal opdateres (standard passer til dette projekt).
GITHUB_REPO_OWNER=vincent4
GITHUB_REPO_NAME=vika-ooe
GITHUB_BRANCH=main
